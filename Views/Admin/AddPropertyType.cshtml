@model Propertytype
@{
    ViewBag.Title = "Add Property Type - Admin";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-6 offset-lg-3">
            <div class="card">
                <div class="card-header">
                    <h4 style="margin: 0;"><i class="fas fa-plus"></i> Add New Property Type</h4>
                </div>
                <div class="card-body">
                    <form method="post" novalidate>
                        <div class="mb-3">
                            <label class="form-label">Type Name</label>
                            <input asp-for="TypeName" class="form-control" required>
                            <span asp-validation-for="TypeName" class="invalid-feedback"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-plus"></i> Add Type
                            </button>
                            <a href="/Admin/ManagePropertyTypes" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>