@{
    ViewBag.Title = "System Reports - Admin";
}

<div class="container py-5">
    <h2 style="color: #B8956D; font-weight: bold; margin-bottom: 2rem;">
        <i class="fas fa-chart-bar"></i> System Reports
    </h2>

    <!-- Summary Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <i class="fas fa-users"></i>
                <div class="stat-number">@ViewBag.TotalUsers</div>
                <div class="stat-label">Total Users</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #8B7355 0%, #6B5744 100%);">
                <i class="fas fa-building"></i>
                <div class="stat-number">@ViewBag.TotalProperties</div>
                <div class="stat-label">Total Properties</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <i class="fas fa-envelope"></i>
                <div class="stat-number">@ViewBag.TotalEnquiries</div>
                <div class="stat-label">Total Enquiries</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #8B7355 0%, #6B5744 100%);">
                <i class="fas fa-calendar"></i>
                <div class="stat-number">@ViewBag.TotalVisits</div>
                <div class="stat-label">Total Site Visits</div>
            </div>
        </div>
    </div>

    <!-- Reports -->
    <div class="row">
        <!-- Users by Type -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 style="margin: 0;"><i class="fas fa-users"></i> Users by Type</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>User Type</th>
                                <th>Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.UsersByType)
                            {
                                <tr>
                                    <td>@item.Type</td>
                                    <td><strong>@item.Count</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Properties by Status -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 style="margin: 0;"><i class="fas fa-building"></i> Properties by Status</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.PropertiesByStatus)
                            {
                                <tr>
                                    <td>@item.Status</td>
                                    <td><strong>@item.Count</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Localities -->
    <div class="row">
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 style="margin: 0;"><i class="fas fa-map-marker-alt"></i> Top 10 Localities by Property Count</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Locality</th>
                                <th>Property Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.PropertiesByLocality)
                            {
                                <tr>
                                    <td>@item.Locality</td>
                                    <td><strong>@item.Count</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>