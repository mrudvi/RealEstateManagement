@model List<Locality>
@{
    ViewBag.Title = "Manage Localities - Admin";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 style="color: #B8956D; font-weight: bold; margin-bottom: 1rem;">
                <i class="fas fa-map-marker-alt"></i> Manage Localities
            </h2>
            <a href="/Admin/AddLocality" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add New Locality
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Locality Name</th>
                    <th>Area</th>
                    <th>Zip Code</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var locality in Model)
                {
                    <tr>
                        <td>@locality.LocalityName</td>
                        <td>@locality.Area</td>
                        <td>@locality.ZipCode</td>
                        <td>@(string.IsNullOrEmpty(locality.Description) ? "-" : locality.Description.Substring(0, Math.Min(50, locality.Description.Length)) + "...")</td>
                        <td>
                            @if (locality.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>@locality.CreatedDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <a href="/Admin/EditLocality/@locality.LocalityId" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>