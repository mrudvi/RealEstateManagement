@model List<ActivityLog>
@{
    ViewBag.Title = "Activity Log - Admin";
}

<div class="container py-5">
    <h2 style="color: #B8956D; font-weight: bold; margin-bottom: 2rem;">
        <i class="fas fa-history"></i> System Activity Log
    </h2>

    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity Type</th>
                    <th>Description</th>
                    <th>IP Address</th>
                    <th>Date & Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.User?.FullName</td>
                        <td><span class="badge bg-info">@log.Action</span></td>
                        <td>@log.EntityType</td>
                        <td>@log.Description</td>
                        <td><small>@log.IPAddress</small></td>
                        <td>@log.CreatedDate.ToString("dd MMM yyyy hh:mm tt")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>