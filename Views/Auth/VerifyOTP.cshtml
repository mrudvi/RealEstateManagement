@{
    ViewBag.Title = "Verify Email - Real Estate Surat";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card">
                <div class="card-header">
                    <h4 style="margin: 0;"><i class="fas fa-shield-alt"></i> Email Verification</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <p>@error.ErrorMessage</p>
                                }
                            }
                        </div>
                    }

                    <form method="post" action="/Auth/VerifyOTP">
                        <input type="hidden" name="email" value="@ViewBag.Email">

                        <div class="alert alert-info mb-4">
                            <i class="fas fa-info-circle"></i> 
                            We've sent a 6-digit OTP to <strong>@ViewBag.Email</strong>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Enter OTP</label>
                            <input type="text" name="otp" class="form-control form-control-lg text-center" 
                                   placeholder="000000" maxlength="6" inputmode="numeric" required>
                            <small class="text-muted">6-digit code</small>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">
                            <i class="fas fa-check"></i> Verify OTP
                        </button>

                        <div class="text-center">
                            <p>Didn't receive OTP? 
                                <a href="/Auth/ResendOTP?email=@ViewBag.Email" class="link-primary">Resend</a>
                            </p>
                        </div>

                        <hr>
                        <div class="text-center">
                            <a href="/Auth/Login">Back to Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Only allow numbers
    document.querySelector('input[name="otp"]').addEventListener('input', function(e) {
        e.target.value = e.target.value.replace(/[^0-9]/g, '');
    });
</script>