@model List<Property>

@{
    ViewBag.Title = "Dashboard";
}

<div class="container py-5">
    <h2 style="color: #B8956D; font-weight: bold; margin-bottom: 2rem;">
    <i class="fas fa-tachometer-alt"></i> Customer Dashboard

    @if (ViewBag.IsOwner == true && ViewBag.IsVerified != true)
    {
        <span class="badge bg-warning ms-2">
            Owner Pending Approval
        </span>
    }
</h2>

    <!-- Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <i class="fas fa-heart"></i>
                <div class="stat-number">@ViewBag.TotalFavorites</div>
                <div class="stat-label">Favorites</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #8B7355 0%, #6B5744 100%);">
                <i class="fas fa-envelope"></i>
                <div class="stat-number">@ViewBag.TotalEnquiries</div>
                <div class="stat-label">Enquiries</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <i class="fas fa-calendar"></i>
                <div class="stat-number">0</div>
                <div class="stat-label">Scheduled Visits</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #8B7355 0%, #6B5744 100%);">
                <i class="fas fa-building"></i>
                <div class="stat-number">@Model.Count</div>
                <div class="stat-label">Available Properties</div>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <a href="/Customer/MyFavorites" class="btn btn-primary me-2">
                        <i class="fas fa-heart"></i> My Favorites
                    </a>
                    <a href="/Customer/MyEnquiries" class="btn btn-primary me-2">
                        <i class="fas fa-envelope"></i> My Enquiries
                    </a>
                    <a href="/Customer/MySiteVisits" class="btn btn-primary me-2">
                        <i class="fas fa-calendar"></i> My Site Visits
                    </a>
                    <a href="/PropertyOwner/AddProperty" class="btn btn-success me-2">
                    <i class="fas fa-plus"></i> Add Property
                </a>
                 <a href="/Customer/Profile" class="btn btn-primary">
                        <i class="fas fa-user-circle"></i> My Profile
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Featured Properties -->
    <h3 style="color: #B8956D; font-weight: bold; margin-bottom: 1.5rem;">
        <i class="fas fa-star"></i> Featured Properties
    </h3>
    <div class="row">
        @if (Model != null && Model.Any(p => p.IsVerified && p.Status == PropertyStatus.Active))
        {
            @foreach (var property in Model.Where(p => p.IsVerified && p.Status == PropertyStatus.Active))
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card property-card">
                        <div style="position: relative;">
                            <img src="@property.MainImage" alt="@property.PropertyTitle" class="property-image">
                            <span class="property-badge">₹@property.PropertyPrice.ToString("N0")</span>
                        </div>
                        <div class="property-details">
                            <h5 class="property-title">@property.PropertyTitle</h5>
                            <div class="property-locality">
                                <i class="fas fa-map-marker-alt"></i> @property.Locality.LocalityName
                            </div>
                            <div class="property-specs">
                                <div class="property-spec">
                                    <i class="fas fa-ruler"></i> @property.PropertyArea @property.AreaUnit
                                </div>
                                @if (property.Bedrooms > 0)
                                {
                                    <div class="property-spec">
                                        <i class="fas fa-bed"></i> @property.Bedrooms BHK
                                    </div>
                                }
                            </div>
                            <div class="mt-2">
                                <a href="/Home/PropertyDetails/@property.PropertyId" class="btn btn-sm btn-primary w-100">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No properties available. <a href="/Home/Search">Search properties</a>
                </div>
            </div>
        }
    </div>
</div>

    <!-- ================= OWNER SECTION ================= -->
    @if (ViewBag.IsOwner == true)
    {
        <hr />

        <h3 class="section-title">
            <i class="fas fa-home"></i> Property Owner Panel
        </h3>

        @if (ViewBag.IsVerified == true)
        {
            <!-- OWNER STATS -->
            <div class="row mb-4">

                <div class="col-md-4">
                    <div class="stat-card">
                        <i class="fas fa-building"></i>
                        <div class="stat-number">@ViewBag.TotalProperties</div>
                        <div class="stat-label">Total Properties</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="stat-card dark">
                        <i class="fas fa-envelope"></i>
                        <div class="stat-number">@ViewBag.TotalEnquiries</div>
                        <div class="stat-label">Enquiries Received</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="stat-card">
                        <i class="fas fa-calendar"></i>
                        <div class="stat-number">@ViewBag.TotalVisits</div>
                        <div class="stat-label">Site Visits</div>
                    </div>
                </div>

            </div>

            <!-- OWNER ACTIONS -->
            <div class="mb-4">
                <a href="/PropertyOwner/AddProperty" class="btn btn-main me-2">
                    <i class="fas fa-plus"></i> Add Property
                </a>

                <a href="/PropertyOwner/PropertyEnquiries/0" class="btn btn-main me-2">
                    <i class="fas fa-envelope"></i> View Enquiries
                </a>

                <a href="/PropertyOwner/Profile" class="btn btn-main">
                    <i class="fas fa-user-circle"></i> Profile
                </a>
            </div>

            <!-- OWNER PROPERTY TABLE -->
            <h4 class="section-title">
                <i class="fas fa-home"></i> My Properties
            </h4>

            @if (Model != null && Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover custom-table">

                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Location</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Verified</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var property in Model)
                            {
                                <tr>
                                    <td>@property.PropertyTitle</td>
                                    <td>@property.PropertyType?.TypeName</td>
                                    <td>@property.Locality?.LocalityName</td>
                                    <td>₹@property.PropertyPrice.ToString("N0")</td>

                                    <td>
                                        <span class="badge bg-@GetStatusColor(property.Status)">
                                            @property.Status
                                        </span>
                                    </td>

                                    <td>
                                        @if (property.IsVerified)
                                        {
                                            <span class="badge bg-success">Verified</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                    </td>

                                    <td>
                                        <a href="/PropertyOwner/EditProperty/@property.PropertyId"
                                           class="btn btn-sm btn-main me-1">
                                            Edit
                                        </a>

                                        <a href="/PropertyOwner/PropertyEnquiries/@property.PropertyId"
                                           class="btn btn-sm btn-info">
                                            Enquiries
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    No properties added yet.
                </div>
            }
        }
        else
        {
            <!-- PENDING UI -->
            <div class="alert alert-warning">
                ⏳ Your property is under admin verification.<br />
                Owner features will unlock after approval.
            </div>
        }
    }

</div>

@functions {
    string GetStatusColor(PropertyStatus status)
    {
        return status switch
        {
            PropertyStatus.Active => "success",
            PropertyStatus.Pending => "warning",
            PropertyStatus.Inactive => "danger",
            PropertyStatus.Sold => "info",
            PropertyStatus.Rented => "primary",
            _ => "secondary"
        };
    }
}