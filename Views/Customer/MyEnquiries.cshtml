@model List<Enquiry>
@{
    ViewBag.Title = "My Enquiries - Customer";
}

<div class="container py-5">
    <h2 style="color: #B8956D; font-weight: bold; margin-bottom: 2rem;">
        <i class="fas fa-envelope"></i> My Enquiries
    </h2>

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Message</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var enquiry in Model)
                    {
                        <tr>
                            <td>@enquiry.Property?.PropertyTitle</td>
                            <td>@enquiry.EnquiryMessage.Substring(0, Math.Min(50, enquiry.EnquiryMessage.Length))...</td>
                            <td>
                                <span class="badge bg-@GetStatusColor(enquiry.EnquiryStatus)">@enquiry.EnquiryStatus</span>
                            </td>
                            <td>
                                <span class="badge bg-@GetPriorityColor(enquiry.Priority)">@enquiry.Priority</span>
                            </td>
                            <td>@enquiry.CreatedDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <a href="/Home/PropertyDetails/@enquiry.PropertyId" class="btn btn-sm btn-primary">
                                    <i class="fas fa-eye"></i> View Property
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> You haven't submitted any enquiries yet.
        </div>
    }
</div>

@functions {
    string GetStatusColor(EnquiryStatus status)
    {
        return status switch
        {
            EnquiryStatus.New => "info",
            EnquiryStatus.InProgress => "warning",
            EnquiryStatus.Contacted => "primary",
            EnquiryStatus.Closed => "success",
            EnquiryStatus.Rejected => "danger",
            _ => "secondary"
        };
    }

    string GetPriorityColor(Priority priority)
    {
        return priority switch
        {
            Priority.Low => "info",
            Priority.Medium => "warning",
            Priority.High => "danger",
            _ => "secondary"
        };
    }
}